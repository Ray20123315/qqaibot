+    entry.token = token;
+    const now = Date.now();
+    const deadline = Number(entry.firstAt || now) + DEFAULTS.inputDebounceMaxMs;
+    const delay = Math.max(0, Math.min(DEFAULTS.inputDebounceMs, deadline - now));
+    entry.fireAt = now + delay;
+    this.inputBuffers.set(key, entry);
