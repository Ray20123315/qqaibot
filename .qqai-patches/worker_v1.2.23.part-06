+      if (!part) continue;
+      const id = String(part.message_id || "");
+      const key = id || `${String(part.time || "")}:${eventPlainText(part)}`;
+      if (seen.has(key)) continue;
+      seen.add(key);
+      output.push(part);
+    }
+    return output;
+  }
+
+  scheduleInputBuffer(key) {
+    const entry = this.inputBuffers.get(key);
+    if (!entry) return;
