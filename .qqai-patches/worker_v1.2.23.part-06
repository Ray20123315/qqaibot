+      await this.flushBufferedQuestion(key, "debounce");
+    })().catch(error => console.error("input debounce failed", error)));
+  }
+
+  async bufferQuestionParts(key, parts, requestUrl, { notify = false } = {}) {
+    const now = Date.now();
