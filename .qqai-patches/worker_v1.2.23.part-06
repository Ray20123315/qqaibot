+  }
+
+  async flushBufferedQuestion(key, reason = "manual") {
+    const entry = this.inputBuffers.get(key);
+    if (!entry) return false;
+    if (this.userInFlight.has(key)) {
+      if (reason === "poke" || reason === "answer_now") {
+        entry.forceImmediate = true;
